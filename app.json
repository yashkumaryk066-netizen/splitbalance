{
  "expo": {
    "name": "SettleStack",
    "slug": "splitbalance",
    "version": "1.2.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "settlestack",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e1b4b"
    },
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tele.settlestack",
      "userInterfaceStyle": "automatic"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1e1b4b"
      },
      "package": "com.tele.settlestack",
      "userInterfaceStyle": "automatic",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "name": "SettleStack | Split Expenses by Yash ankush Mishra",
      "shortName": "SettleStack",
      "description": "SettleStack (SplitBalance) is the easiest way to share expenses with friends and family. A project by Yashankush Mishra.",
      "themeColor": "#1e1b4b",
      "background_color": "#ffffff",
      "display": "standalone"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SettleStack to access your photos to upload bill receipts.",
          "cameraPermission": "Allow SettleStack to use the camera to snap bill receipts."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow SettleStack to access your contacts to easily invite friends to your groups."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6b7828b3-1318-4152-993e-315cb34c3789"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6b7828b3-1318-4152-993e-315cb34c3789"
    }
  }
}
